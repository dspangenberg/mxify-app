{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:ssr": "vite build && vite build --ssr",
    "dev": "vite",
    "lint": "pnpm  dlx @biomejs/biome lint .",
    "format:check": "pnpm  dlx @biomejs/biome format .",
    "format:write": "pnpm  dlx @biomejs/biome format --write resources/js/*",
    "types": "tsc --noEmit",
    "registry:build": "shadcn build",
    "registry:create": "tsx scripts/create-registry.ts && tsx scripts/sync-changelog.ts",
    "build:docs": "tsx scripts/build-docs-structure.ts",
    "sync:changelog": "tsx scripts/sync-changelog.ts",
    "test": "NODE_ENV=test vitest --config vitest.config.ts",
    "test:watch": "NODE_ENV=test vitest --watch --config vitest.config.ts",
    "test:ui": "NODE_ENV=test vitest --ui --config vitest.config.ts",
    "test:coverage": "NODE_ENV=test vitest --coverage --config vitest.config.ts",
    "postinstall": "react-flagpack"
  },
